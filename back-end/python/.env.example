# APP
APP_HOST=0.0.0.0
APP_PORT=8000

# DB (dev)
DATABASE_URL=sqlite:///./dev.db

# Storage provider: local (mock) ou aws
STORAGE_PROVIDER=local

# OTP (código de 6 dígitos)
OTP_MAX_ATTEMPTS=5    # máximo de tentativas por código
OTP_COOLDOWN_MINUTES=15 # minutos de bloqueio após exceder tentativas
OTP_VALIDITY_MINUTES=10 # validade padrão do código


# ACCESS token (janela de acesso ao share)
ACCESS_VALID_HOURS=24   # horas de validade do ACCESS emitido após verificar OTP

# Presigned/mock TTL para download de arquivo
PRESIGNED_TTL_SECONDS_DEFAULT=300

# Auth provider (feature flag)
AUTH_MODE=local     # depois troque para 'entra' quando integrar

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
JWT_SECRET_KEY=change_me
