# ============================================================
# BACKEND (Python/FastAPI) - Variaveis para RODAR LOCAL
# ============================================================
# Arquivo: backend-local.env
# Como usar: copie este arquivo para backend/.env
#   cp ENV/backend-local.env backend/.env
# ============================================================


# Banco: conecta no Neon (ou deixe vazio para usar SQLite local)
DATABASE_URL=postgresql://USER:SENHA@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Chave JWT (pode ser qualquer texto para desenvolvimento)
JWT_SECRET_KEY=chave-secreta-local-para-desenvolvimento

# Email em modo dev (so mostra no console, nao envia de verdade)
EMAIL_PROVIDER=dev

# Storage em modo local (salva no disco, nao no S3)
STORAGE_PROVIDER=local

# Auth em modo local (login com usuario/senha, sem Entra ID)
AUTH_MODE=local

# URL do frontend local
FRONTEND_EXTERNAL_PORTAL_URL=http://localhost:3000
