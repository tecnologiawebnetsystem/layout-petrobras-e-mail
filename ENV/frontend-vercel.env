# ============================================================
# FRONTEND (Next.js) - Variaveis para a Vercel
# ============================================================
# Arquivo: frontend-vercel.env
# Onde configurar: Vercel > Settings > Environment Variables
# ============================================================


# ------------------------------------------------------------
# 1. CONEXAO COM O BACKEND (OBRIGATORIO)
# ------------------------------------------------------------
# URL do backend Python no Render (sem barra no final)
# Onde pegar: Render Dashboard > seu servico > URL no topo
BACKEND_URL=https://layout-petrobras-e-mail.onrender.com


# ------------------------------------------------------------
# 2. CONEXAO COM O BANCO DE DADOS (OBRIGATORIO)
# ------------------------------------------------------------
# String de conexao do Neon PostgreSQL
# Onde pegar: Neon Console > seu projeto > Connection Details > Connection string
DATABASE_URL=postgresql://USER:SENHA@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require


# ------------------------------------------------------------
# 3. MICROSOFT ENTRA ID - SSO Petrobras (OBRIGATORIO em producao)
# ------------------------------------------------------------
# Onde pegar: Azure Portal > App Registrations > sua app
NEXT_PUBLIC_ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Opcional - se nao definir, usa window.location.origin automaticamente
# NEXT_PUBLIC_ENTRA_REDIRECT_URI=https://seu-app.vercel.app


# ------------------------------------------------------------
# 4. URL PUBLICA DO APP (OPCIONAL)
# ------------------------------------------------------------
# Usado nos templates de email para gerar links corretos
# Se nao definir, usa fallback interno
# NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app


# ------------------------------------------------------------
# 5. API CLIENT (OPCIONAL)
# ------------------------------------------------------------
# URL base para chamadas client-side (padrao: /api)
# Normalmente nao precisa mudar
# NEXT_PUBLIC_API_URL=/api
