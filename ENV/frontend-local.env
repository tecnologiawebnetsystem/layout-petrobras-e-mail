# ============================================================
# FRONTEND (Next.js) - Variaveis para RODAR LOCAL
# ============================================================
# Arquivo: frontend-local.env
# Como usar: copie este arquivo para .env.local na raiz do projeto
#   cp ENV/frontend-local.env .env.local
# ============================================================


# Backend rodando na sua maquina
BACKEND_URL=http://localhost:8000

# Banco Neon (necessario para as paginas do Roadmap)
DATABASE_URL=postgresql://USER:SENHA@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Entra ID (deixe vazio para pular SSO e usar login local)
# NEXT_PUBLIC_ENTRA_CLIENT_ID=
# NEXT_PUBLIC_ENTRA_TENANT_ID=
