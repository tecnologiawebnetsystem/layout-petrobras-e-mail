# ============================================================
# BACKEND (Python/FastAPI) - Variaveis para o Render.com
# ============================================================
# Arquivo: backend-render.env
# Onde configurar: Render Dashboard > seu servico > Environment
# ============================================================


# ------------------------------------------------------------
# 1. BANCO DE DADOS (OBRIGATORIO)
# ------------------------------------------------------------
# String de conexao do Neon PostgreSQL
# Onde pegar: Neon Console > seu projeto > Connection Details > Connection string
# ATENCAO: usar o formato postgresql:// (o backend converte automaticamente para psycopg)
DATABASE_URL=postgresql://USER:SENHA@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require


# ------------------------------------------------------------
# 2. SEGURANCA (OBRIGATORIO)
# ------------------------------------------------------------
# Chave secreta para assinar tokens JWT
# Como gerar: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=COLE_AQUI_A_CHAVE_GERADA


# ------------------------------------------------------------
# 3. PYTHON (RECOMENDADO)
# ------------------------------------------------------------
# Versao do Python no Render
PYTHON_VERSION=3.12.0


# ------------------------------------------------------------
# 4. EMAIL (OPCIONAL - para desenvolvimento usar "dev")
# ------------------------------------------------------------
# Provedor de email: "dev" (logs no console) ou "ses" (Amazon SES)
EMAIL_PROVIDER=dev

# Configurar apenas se EMAIL_PROVIDER=ses
# SMTP_SERVER=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIA...
# SMTP_PASS=...
# MAIL_FROM=noreply@petrobras.com.br


# ------------------------------------------------------------
# 5. ARMAZENAMENTO (OPCIONAL - para desenvolvimento usar "local")
# ------------------------------------------------------------
# Provedor de storage: "local" (disco local) ou "aws" (S3)
STORAGE_PROVIDER=local

# Configurar apenas se STORAGE_PROVIDER=aws
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=petrobras-compartilhamento
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...


# ------------------------------------------------------------
# 6. AUTENTICACAO (OPCIONAL)
# ------------------------------------------------------------
# Modo de autenticacao: "local" (usuario/senha) ou "entra" (Microsoft Entra ID)
AUTH_MODE=local

# Configurar apenas se AUTH_MODE=entra
# ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ENTRA_CLIENT_SECRET=xxxxxxxx
# ENTRA_REDIRECT_URI=https://layout-petrobras-e-mail.onrender.com/api/v1/auth/internal/callback


# ------------------------------------------------------------
# 7. LINKS E BRANDING (OPCIONAL)
# ------------------------------------------------------------
# URL do frontend (para gerar links nos emails de reset, OTP, etc.)
FRONTEND_EXTERNAL_PORTAL_URL=https://seu-app.vercel.app

# URL template para detalhes de compartilhamento
# FRONTEND_SHARE_DETAILS_URL=https://seu-app.vercel.app/compartilhamentos/{share_id}

# Nomes exibidos nos emails
# APP_NAME=Compartilhamento Seguro de Arquivos
# COMPANY_NAME=Petrobras
# SUPPORT_EMAIL=suporte@petrobras.com.br


# ------------------------------------------------------------
# 8. OTP E TOKENS (OPCIONAL - valores padrao ja funcionam)
# ------------------------------------------------------------
# OTP_MAX_ATTEMPTS=5
# OTP_COOLDOWN_MINUTES=15
# OTP_VALIDITY_MINUTES=5
# ACCESS_VALID_HOURS=24
# PRESIGNED_TTL_SECONDS_DEFAULT=300
